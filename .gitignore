# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# script caches (ephemeral, not needed in git)
.cache/
scripts/*-cache.json
resolve-candidates-*.csv
sc-followee-duplicates-*.csv
genre-report*.csv
# HÖR resolver / link-migration dated outputs
hoer-status-resolution-*.csv
hoer-inferred-dupes-review-*.csv
hoer-exact-ambiguous-*.csv
hoer-internal-dupes-*.csv
hoer-dupe-review-applied-*.csv
hoer-link-migration-applied-*.csv
__pycache__/
*.pyc

# temporary scripts
_tmp_*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# supabase CLI (ephemeral local/link state; keep config.toml + migrations)
supabase/.branches
supabase/.temp

# typescript
*.tsbuildinfo
next-env.d.ts

# claude local state — settings, agents, and the worktrees it creates
# (those are checkouts of this same repo, so committing them would nest
# a git repository inside itself)
.claude/
