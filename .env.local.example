# Copy this file to .env.local and fill in values from your Supabase
# project: Project Settings -> API Keys (or the "Connect" dialog).

# Project URL (sometimes shown as "API URL"), e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (starts with "sb_publishable_") — safe to expose to the
# browser. Replaces the old "anon" key. RLS policies restrict it to
# read-only access to approved artists.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (starts with "sb_secret_") — SERVER-ONLY, bypasses Row Level
# Security. Replaces the old "service_role" key. Used by /api/submit to
# write moderation-queue submissions.
# Never prefix this with NEXT_PUBLIC_ and never commit it.
SUPABASE_SECRET_KEY=

# ── Email verification (Resend) ──────────────────────────────────────────────
# Sign up at resend.com, verify your sending domain, then copy the API key here.
# The FROM address in lib/email.ts must match a verified domain in your Resend account.
RESEND_API_KEY=
# The "from" address for verification emails. Must match a domain you've
# verified in Resend (Resend dashboard → Domains). e.g. noreply@rebalance-gender.app
# During initial Resend setup before your domain is verified, you can use
# onboarding@resend.dev — but only to send to your own account email.
RESEND_FROM_ADDRESS=

# Full public URL of the site, used to build email verification links.
# In production: https://yourdomain.com  (no trailing slash)
# In development: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Bot protection (Cloudflare Turnstile) ────────────────────────────────────
# Sign in to dash.cloudflare.com → Turnstile → Add site → copy keys below.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY is safe to expose to the browser.
# TURNSTILE_SECRET_KEY must never be committed or prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── SoundCloud API credentials — used by scripts/harvest-soundcloud-links-and-bio.mjs
# to call the official api.soundcloud.com API (web-profiles + bio) instead of
# scraping HTML. Requires a SoundCloud account on the Artist Pro plan:
#   1. https://soundcloud.com/you/apps/new (while signed in) -> register an app
#   2. Copy the Client ID and Client Secret it gives you into the two vars below
# Never commit the secret.
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
